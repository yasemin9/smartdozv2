# SmartDoz Backend - Ortam Değişkenleri
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun.

# PostgreSQL bağlantı URL'si (asyncpg motoru kullanılır)
DATABASE_URL=postgresql+asyncpg://postgres:your_password@localhost:5432/smartdoz

# JWT için güçlü ve rastgele bir gizli anahtar üretin:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# JWT algoritması
ALGORITHM=HS256

# Token geçerlilik süresi (dakika)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Groq API anahtarı — Sesli asistan için gerekli (ücretsiz)
# https://console.groq.com adresinden hesap açıp alabilirsiniz
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
